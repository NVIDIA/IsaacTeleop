#
# camera-streamer.service — installed by `camera_viz.sh deploy`.
# Placeholders are substituted at deploy time; do not hand-edit on the robot.

[Unit]
Description=Camera Streamer (camera_viz)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory={{WORKDIR}}
Environment=PATH={{VENV}}/bin:/usr/local/cuda/bin:/usr/bin:/bin
# cupy-cuda12x from PyPI uses cuda.pathfinder to locate libnvrtc.so.
# On Jetson (aarch64) CUDA libs live under targets/sbsa-linux/lib, which
# isn't in pathfinder's default probe list — expose it via LD_LIBRARY_PATH.
# /usr/local/cuda/lib64 covers x86_64 hosts; harmless on Jetson.
Environment=LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/cuda/targets/sbsa-linux/lib
ExecStart={{VENV}}/bin/python {{WORKDIR}}/camera_streamer.py {{CONFIG}}
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
